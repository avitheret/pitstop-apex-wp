 "size": 18, "sizes": []}, "typography_line_height": {"unit": "em", "size": 1.6, "sizes": []}}, "elements": []}, {"id": "269659d", "elType": "widget", "widgetType": "html", "settings": {"html": "<div style=\"display:grid;grid-template-columns:1fr minmax(360px,520px) 1fr;gap:24px;align-items:center;margin-top:56px;\"><div style=\"display:flex;flex-direction:column;gap:48px;\"><div style=\"position:relative;padding-left:26px;\"><span style=\"position:absolute;top:6px;left:0;width:9px;height:9px;border-radius:50%;background:#e5241b;box-shadow:0 0 0 5px rgba(229,36,27,.18);\"></span><h4 style=\"font-family:'Saira Semi Condensed';font-weight:700;text-transform:uppercase;letter-spacing:.04em;font-size:19px;line-height:1.15;margin:0;color:#f4f4f5;\">Extra-Wide Shoulder Ribs</h4><p style=\"color:#9a9aa3;font-size:15.5px;margin-top:8px;line-height:1.5;\">Maximize the contact patch under load to hold the line through high-speed cornering.</p></div><div style=\"position:relative;padding-left:26px;\"><span style=\"position:absolute;top:6px;left:0;width:9px;height:9px;border-radius:50%;background:#e5241b;box-shadow:0 0 0 5px rgba(229,36,27,.18);\"></span><h4 style=\"font-family:'Saira Semi Condensed';font-weight:700;text-transform:uppercase;letter-spacing:.04em;font-size:19px;line-height:1.15;margin:0;color:#f4f4f5;\">Featherlight Construction</h4><p style=\"color:#9a9aa3;font-size:15.5px;margin-top:8px;line-height:1.5;\">A lightweight casing trims rotating mass for peak responsiveness and quicker turn-in.</p></div><div style=\"position:relative;padding-left:26px;\"><span style=\"position:absolute;top:6px;left:0;width:9px;height:9px;border-radius:50%;background:#e5241b;box-shadow:0 0 0 5px rgba(229,36,27,.18);\"></span><h4 style=\"font-family:'Saira Semi Condensed';font-weight:700;text-transform:uppercase;letter-spacing:.04em;font-size:19px;line-height:1.15;margin:0;color:#f4f4f5;\">Motorsport-Derived Compound</h4><p style=\"color:#9a9aa3;font-size:15.5px;margin-top:8px;line-height:1.5;\">A track-bred rubber formulation that reaches grip temperature fast and stays consistent.</p></div></div><div style=\"position:relative;\"><div style=\"position:absolute;inset:-6%;border-radius:50%;border:1px solid rgba(255,255,255,0.10);\"></div><img src=\"/wp-content/themes/pitstop-apex/assets/images/ph-feat.png\" alt=\"\" style=\"width:100%;height:480px;object-fit:cover;border-radius:50%;\"></div><div style=\"display:flex;flex-direction:column;gap:48px;text-align:right;\"><div style=\"position:relative;padding-right:26px;\"><span style=\"position:absolute;top:6px;right:0;width:9px;height:9px;border-radius:50%;background:#e5241b;box-shadow:0 0 0 5px rgba(229,36,27,.18);\"></span><h4 style=\"font-family:'Saira Semi Condensed';font-weight:700;text-transform:uppercase;letter-spacing:.04em;font-size:19px;line-height:1.15;margin:0;color:#f4f4f5;\">Optimized Center Rib</h4><p style=\"color:#9a9aa3;font-size:15.5px;margin-top:8px;line-height:1.5;\">A continuous center band stabilizes the tire under hard braking for shorter, surer stops.</p></div><div style=\"position:relative;padding-right:26px;\"><span style=\"position:absolute;top:6px;right:0;width:9px;height:9px;border-radius:50%;background:#e5241b;box-shadow:0 0 0 5px rgba(229,36,27,.18);\"></span><h4 style=\"font-family:'Saira Semi Condensed';font-weight:700;text-transform:uppercase;letter-spacing:.04em;font-size:19px;line-height:1.15;margin:0;color:#f4f4f5;\">RS-DNA Technology</h4><p style=\"color:#9a9aa3;font-size:15.5px;margin-top:8px;line-height:1.5;\">Decades of racing know-how distilled into a tread pattern tuned for the absolute limit.</p></div><div style=\"position:relative;padding-right:26px;\"><span style=\"position:absolute;top:6px;right:0;width:9px;height:9px;border-radius:50%;background:#e5241b;box-shadow:0 0 0 5px rgba(229,36,27,.18);\"></span><h4 style=\"font-family:'Saira Semi Condensed';font-weight:700;text-transform:uppercase;letter-spacing:.04em;font-size:19px;line-height:1.15;margin:0;c